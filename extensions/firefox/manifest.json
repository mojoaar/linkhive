{
  "name": "LinkHive",
  "version": "1.0.0",
  "description": "Save links to your LinkHive collections directly from the browser",
  "manifest_version": 3,
  "permissions": [
    "activeTab",
    "storage"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      }
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "theme_icons": [
    {
      "light": "icons/icon-16.png",
      "dark": "icons-dark/icon-16.png",
      "size": 16
    },
    {
      "light": "icons/icon-48.png",
      "dark": "icons-dark/icon-48.png",
      "size": 48
    },
    {
      "light": "icons/icon-128.png",
      "dark": "icons-dark/icon-128.png",
      "size": 128
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "linkhive@mojoaar",
      "strict_min_version": "109.0"
    }
  }
}
